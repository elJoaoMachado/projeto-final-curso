# Firebase Emulator Configuration
# Use these settings when running the app with local Firebase emulators

# Enable emulator use
REACT_APP_FIREBASE_USE_EMULATOR=true

# Emulator host addresses
REACT_APP_FIRESTORE_EMULATOR_HOST=localhost:8080
REACT_APP_FUNCTIONS_EMULATOR_HOST=localhost:5001
REACT_APP_AUTH_EMULATOR_HOST=http://localhost:9099

# Firebase Configuration (same as .env, but used by emulator-local build)
REACT_APP_FIREBASE_API_KEY=$REACT_APP_FIREBASE_API_KEY
REACT_APP_FIREBASE_AUTH_DOMAIN=$REACT_APP_FIREBASE_AUTH_DOMAIN
REACT_APP_FIREBASE_PROJECT_ID=projetofinal-f4f26
REACT_APP_FIREBASE_STORAGE_BUCKET=$REACT_APP_FIREBASE_STORAGE_BUCKET
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=$REACT_APP_FIREBASE_MESSAGING_SENDER_ID
REACT_APP_FIREBASE_APP_ID=$REACT_APP_FIREBASE_APP_ID
REACT_APP_FIREBASE_MEASUREMENT_ID=$REACT_APP_FIREBASE_MEASUREMENT_ID
